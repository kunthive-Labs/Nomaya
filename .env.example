# Nomaya — provider credentials. Copy to `.env` and fill in the one(s) you use.
# Nomaya routes every provider through LiteLLM, so you only set the keys for
# the labs you actually want to evaluate. With NO keys set, the suite runs in
# deterministic `mock` mode (great for CI and offline demos).

# --- Leading labs (set whichever you have) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=

# Self-hosted / local models via Ollama (no key needed, just the base URL)
OLLAMA_API_BASE=http://localhost:11434

# --- Nomaya defaults ---
# Model that plays the "agent under test". Use any LiteLLM model string, e.g.:
#   openai/gpt-4o-mini | anthropic/claude-haiku-4-5 | gemini/gemini-2.0-flash | ollama/llama3.1
NOMAYA_AGENT_MODEL=mock/compliant-agent

# Model used as the LLM-judge for subjective rules (UDAAP fairness, tone, etc.)
NOMAYA_JUDGE_MODEL=mock/judge

# Where run results + the SQLite history live
NOMAYA_DB_PATH=nomaya.sqlite3

# --- API hardening ---
# Bearer token required by every API route except /api/health. Leave empty to
# disable auth for local development.
NOMAYA_API_TOKEN=

# Models POST /api/run may target (comma-separated LiteLLM strings). Defaults
# to the mock models only, so a stray caller can't spend provider credits.
# Use "*" to allow any model.
NOMAYA_ALLOWED_MODELS=mock/compliant-agent,mock/naive-agent,mock/judge

# Browser origins allowed by CORS (only relevant when the dashboard talks to
# the API directly instead of through its proxy).
NOMAYA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
