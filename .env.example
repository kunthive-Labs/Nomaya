# Nomaya — provider credentials. Copy to `.env` and fill in the one(s) you use.
# Nomaya routes every provider through LiteLLM, so you only set the keys for
# the labs you actually want to evaluate. With NO keys set, the suite runs in
# deterministic `mock` mode (great for CI and offline demos).

# --- Leading labs (set whichever you have) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=
TOGETHERAI_API_KEY=

# Self-hosted / local models via Ollama (no key needed, just the base URL)
OLLAMA_API_BASE=http://localhost:11434

# --- Nomaya defaults ---
# Model that plays the "agent under test". Use any LiteLLM model string, e.g.:
#   openai/gpt-4o-mini | anthropic/claude-haiku-4-5 | gemini/gemini-2.0-flash | ollama/llama3.1
NOMAYA_AGENT_MODEL=mock/compliant-agent

# Version recorded on every run. Bump when the approved scenario corpus changes.
NOMAYA_SUITE_VERSION=2026.1

# Model used as the LLM-judge for subjective rules (UDAAP fairness, tone, etc.)
NOMAYA_JUDGE_MODEL=mock/judge

# Where run results + the SQLite history live
NOMAYA_DB_PATH=nomaya.sqlite3

# Durable run history and report artifacts are redacted before writing by
# default. Keep this enabled outside of tightly controlled local debugging.
NOMAYA_STORAGE_REDACT_PII=true

# Apply owner-only permissions to the SQLite database on POSIX systems.
NOMAYA_ENFORCE_PRIVATE_STORAGE=true

# Optional automatic deletion of runs older than this many days. Leave empty
# to manage retention with a scheduled call to store.purge_runs(...).
NOMAYA_RETENTION_DAYS=

# Set to production to require an API token and reject wildcard model/CORS
# allow-lists during API startup.
NOMAYA_ENV=development

# --- API hardening ---
# Bearer token required by every API route except /api/health. Leave empty to
# disable auth for local development.
NOMAYA_API_TOKEN=

# Optional least-privilege credentials. A reader can inspect results; a runner
# can submit/cancel evaluations; an admin has both permissions. In production,
# inject these from your identity-aware proxy or secret manager rather than
# committing literal values.
NOMAYA_READ_TOKEN=
NOMAYA_RUN_TOKEN=
NOMAYA_ADMIN_TOKEN=

# Models POST /api/run may target (comma-separated LiteLLM strings). Defaults
# to the mock models only, so a stray caller can't spend provider credits.
# Use "*" to allow any model.
NOMAYA_ALLOWED_MODELS=mock/compliant-agent,mock/naive-agent,mock/judge

# Browser origins allowed by CORS (only relevant when the dashboard talks to
# the API directly instead of through its proxy).
NOMAYA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Evaluation execution limits ---
# The in-process job API accepts queued work up to these bounds. Use a durable
# worker/queue in a multi-instance deployment.
NOMAYA_MAX_CONCURRENT_RUNS=2
NOMAYA_MAX_QUEUED_RUNS=20
NOMAYA_MAX_RUN_SCENARIOS=100
# Set a non-zero budget in production to stop expensive provider runs early.
NOMAYA_MAX_RUN_COST_USD=0
NOMAYA_MAX_RUN_DURATION_SECONDS=900
