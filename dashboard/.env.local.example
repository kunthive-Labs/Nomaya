# Where the Next.js server-side proxy forwards API requests (run `nomaya serve`).
NOMAYA_API_URL=http://127.0.0.1:8000

# Bearer token forwarded by the proxy — set only if the API has NOMAYA_API_TOKEN.
# Stays server-side; it is never shipped to the browser.
NOMAYA_API_TOKEN=

# Optional escape hatch: talk to the FastAPI service directly from the browser,
# bypassing the proxy (no token support; API CORS must allow this origin).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
